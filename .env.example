# Required
LLM_API_KEY=your_api_key_here

# Optional (defaults shown)
LLM_PROVIDER=kimi-coding
LLM_API_BASE_URL=https://api.kimi.com/coding/
LLM_MODEL=kimi-for-coding
LLM_TIMEOUT_SECS=300
# Keep this value for kimi-coding compatibility. Some Kimi client environments require this user-agent.
LLM_USER_AGENT=openclaw

# Optional: custom skills directory
# SKILLS_DIR=./skills
